PORT=4500
NODE_ENV=development
FRONTEND_URL=http://localhost:4100

# PostgreSQL — local: 127.0.0.1 | remote LAN server: your-server-ip
DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/smart_school

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d

# Admin seed credentials
ADMIN_EMAIL=admin@smartschool.edu
ADMIN_PASSWORD=Admin@123456

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=smart-school-verify

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Razorpay (online fee payments — optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMS (twilio | msg91 | mock)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SMARTS
